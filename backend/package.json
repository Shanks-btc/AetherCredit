{
  "name": "@aethercredit/backend",
  "version": "0.1.0",
  "description": "AetherCredit — credit ledger backend for autonomous AI agents on 0G",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node --project tsconfig.scripts.json src/db/migrate.ts",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "validate": "ts-node --project tsconfig.scripts.json scripts/validate.ts"
  },
  "dependencies": {
    "@0gfoundation/0g-compute-ts-sdk": "^0.8.3",
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.9",
    "@0gfoundation/0g-ts-sdk": "^1.2.8",
    "@0glabs/0g-serving-broker": "^2.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.13.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
